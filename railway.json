{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd blog-backend && mvn clean package -DskipTests",
    "nixpacksConfigPath": "blog-backend/nixpacks.toml"
  },
  "deploy": {
    "startCommand": "java -jar blog-backend/target/*.jar --server.port=${PORT}",
    "numReplicas": 1
  }
}
